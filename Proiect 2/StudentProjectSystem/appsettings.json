{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=app.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "FileUpload": {
    "MaxFileSizeMB": 50,
    "AllowedExtensions": ".pdf,.zip,.rar,.docx,.doc,.pptx,.txt,.cs,.py,.js,.html"
  }
}
