@model IEnumerable<AuditLog>
@{ ViewData["Title"] = "Jurnale Audit"; }

<div class="card-header mb-4">
    <p class="text-muted">Logurile sunt protejate împotriva modificărilor. Păstrate minim 30 zile.</p>
</div>

<div class="table-card">
    <table class="data-table">
        <thead>
            <tr><th>#</th><th>Acțiune</th><th>Detalii</th><th>Utilizator</th><th>IP</th><th>Data/Ora</th></tr>
        </thead>
        <tbody>
            @foreach (var log in Model)
            {
                <tr>
                    <td class="text-muted">@log.LogId</td>
                    <td><span class="log-action log-@log.Action.ToLower()">@log.Action</span></td>
                    <td><small>@log.Details</small></td>
                    <td>@(log.User?.FullName ?? "—")</td>
                    <td><small class="text-muted">@(log.IpAddress ?? "—")</small></td>
                    <td>@log.CreatedAt.ToString("dd.MM.yyyy HH:mm:ss")</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Pagination -->
<div class="pagination">
    @for (int i = 1; i <= ViewBag.TotalPages; i++)
    {
        <a asp-action="Logs" asp-route-page="@i"
           class="page-btn @(i == ViewBag.Page ? "active" : "")">@i</a>
    }
</div>
