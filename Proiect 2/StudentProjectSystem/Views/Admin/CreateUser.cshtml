@model CreateUserViewModel
@{ ViewData["Title"] = "Utilizator Nou"; }

<div class="card card-narrow">
    <div class="card-header">
        <h2><i class="fas fa-user-plus"></i> Creare Utilizator</h2>
    </div>
    <div class="card-body">
        <form asp-action="CreateUser" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="form-group">
                <label asp-for="FullName"><i class="fas fa-user"></i> Nume complet</label>
                <input asp-for="FullName" class="form-control" placeholder="ex: Ionescu Andrei" />
                <span asp-validation-for="FullName" class="field-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="Email"><i class="fas fa-envelope"></i> Email</label>
                <input asp-for="Email" class="form-control" placeholder="ex: ionescu@university.ro" />
                <span asp-validation-for="Email" class="field-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="Password"><i class="fas fa-lock"></i> Parolă</label>
                <input asp-for="Password" class="form-control" placeholder="Minim 6 caractere" />
                <span asp-validation-for="Password" class="field-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="Role"><i class="fas fa-id-badge"></i> Rol</label>
                <select asp-for="Role" class="form-control">
                    <option value="Student">Student</option>
                    <option value="Professor">Profesor</option>
                    <option value="Admin">Administrator</option>
                </select>
                <span asp-validation-for="Role" class="field-error"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Creează</button>
                <a asp-action="Users" class="btn btn-secondary">Anulează</a>
            </div>
        </form>
    </div>
</div>
