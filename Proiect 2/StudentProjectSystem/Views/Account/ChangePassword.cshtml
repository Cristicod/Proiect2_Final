@model ChangePasswordViewModel
@{ ViewData["Title"] = "Schimbă Parola"; }

<div class="card card-narrow">
    <div class="card-header">
        <h2><i class="fas fa-key"></i> Schimbă Parola</h2>
    </div>
    <div class="card-body">
        <form asp-action="ChangePassword" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="form-group">
                <label asp-for="CurrentPassword"></label>
                <input asp-for="CurrentPassword" class="form-control" />
                <span asp-validation-for="CurrentPassword" class="field-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="NewPassword"></label>
                <input asp-for="NewPassword" class="form-control" />
                <span asp-validation-for="NewPassword" class="field-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="ConfirmPassword"></label>
                <input asp-for="ConfirmPassword" class="form-control" />
                <span asp-validation-for="ConfirmPassword" class="field-error"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Salvează</button>
                <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Anulează</a>
            </div>
        </form>
    </div>
</div>
