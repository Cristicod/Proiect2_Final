@model LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Autentificare";
}
<!DOCTYPE html>
<html lang="ro">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login – UniProjects</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="login-body">

<div class="login-page">
    <div class="login-illustration">
        <div class="illustration-content">
            <div class="illustration-icon"><i class="fas fa-graduation-cap"></i></div>
            <h2>Sistem de Administrare Proiecte</h2>
            <p>Platformă centralizată pentru studenți, profesori și administratori universitari.</p>
            <div class="features-list">
                <div class="feature-item"><i class="fas fa-upload"></i> Încarcă proiecte</div>
                <div class="feature-item"><i class="fas fa-star"></i> Primești note și feedback</div>
                <div class="feature-item"><i class="fas fa-comments"></i> Comunică cu profesorii</div>
                <div class="feature-item"><i class="fas fa-chart-line"></i> Monitorizează progresul</div>
            </div>
        </div>
    </div>

    <div class="login-form-side">
        <div class="login-card">
            <div class="login-brand">
                <i class="fas fa-graduation-cap"></i>
                <span>UniProjects</span>
            </div>
            <h1>Bun venit!</h1>
            <p class="login-subtitle">Autentifică-te în contul tău</p>

            <form asp-action="Login" method="post" novalidate>
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

                <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

                <div class="form-group">
                    <label asp-for="Email"><i class="fas fa-envelope"></i> Email</label>
                    <input asp-for="Email" class="form-control" placeholder="exemplu@university.ro" autofocus />
                    <span asp-validation-for="Email" class="field-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Password"><i class="fas fa-lock"></i> Parolă</label>
                    <div class="input-group">
                        <input asp-for="Password" class="form-control" id="passwordInput" placeholder="••••••••" />
                        <button type="button" class="input-addon" onclick="togglePassword()">
                            <i class="fas fa-eye" id="eyeIcon"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="field-error"></span>
                </div>

                <div class="form-check-row">
                    <label class="checkbox-label">
                        <input asp-for="RememberMe" type="checkbox" />
                        <span>Rămâi conectat</span>
                    </label>
                </div>

                <button type="submit" class="btn btn-primary btn-full">
                    <i class="fas fa-sign-in-alt"></i> Autentifică-te
                </button>
            </form>

            <div class="login-demo">
                <p>Conturi demo (parola: <strong>Password123!</strong>):</p>
                <div class="demo-accounts">
                    <button onclick="fillLogin('admin@university.ro')"    class="demo-btn admin">Admin</button>
                    <button onclick="fillLogin('ionescu@university.ro')"  class="demo-btn professor">Profesor</button>
                    <button onclick="fillLogin('mihai.g@student.ro')"     class="demo-btn student">Student</button>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="~/js/site.js"></script>
<script>
function fillLogin(email) {
    document.getElementById('Email').value = email;
    document.getElementById('Password').value = 'Password123!';
}
function togglePassword() {
    const inp  = document.getElementById('passwordInput');
    const icon = document.getElementById('eyeIcon');
    if (inp.type === 'password') { inp.type = 'text'; icon.className = 'fas fa-eye-slash'; }
    else                         { inp.type = 'password'; icon.className = 'fas fa-eye'; }
}
</script>
</body>
</html>
