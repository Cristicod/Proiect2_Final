@model IEnumerable<Project>
@{ ViewData["Title"] = "Proiectele mele"; }

<div class="toolbar">
    <form method="get" class="search-form">
        <div class="input-group">
            <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Caută proiect..." />
            <button type="submit" class="btn btn-primary"><i class="fas fa-search"></i></button>
        </div>
        <select name="status" class="form-control" onchange="this.form.submit()">
            <option value="">Toate statusurile</option>
            <option value="Submitted"    selected="@(ViewBag.Status == "Submitted")">Trimis</option>
            <option value="UnderReview"  selected="@(ViewBag.Status == "UnderReview")">În evaluare</option>
            <option value="Graded"       selected="@(ViewBag.Status == "Graded")">Evaluat</option>
        </select>
    </form>
    <a asp-action="Upload" class="btn btn-primary"><i class="fas fa-plus"></i> Proiect nou</a>
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <i class="fas fa-folder-open"></i>
        <h3>Niciun proiect găsit</h3>
        <p>Încearcă să modifici filtrele sau adaugă un proiect nou.</p>
    </div>
}
else
{
    <div class="table-card">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Titlu</th>
                    <th>Data</th>
                    <th>Status</th>
                    <th>Notă</th>
                    <th>Acțiuni</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td>
                            <div class="cell-title">@p.Title</div>
                            <div class="cell-sub">@(p.Description.Length > 60 ? p.Description[..60] + "…" : p.Description)</div>
                        </td>
                        <td>@p.UploadDate.ToString("dd.MM.yyyy")</td>
                        <td><span class="status-badge status-@p.Status.ToLower()">@p.Status</span></td>
                        <td>
                            @if (p.Grade != null)
                            { <span class="grade-chip">@p.Grade.Score / 10</span> }
                            else
                            { <span class="text-muted">—</span> }
                        </td>
                        <td class="actions-cell">
                            <a asp-action="ProjectDetails" asp-route-id="@p.ProjectId" class="btn-icon" title="Detalii"><i class="fas fa-eye"></i></a>
                            @if (p.Status != "Graded" && !(p.Deadline.HasValue && p.Deadline < DateTime.UtcNow))
                            {
                                <a asp-action="EditProject" asp-route-id="@p.ProjectId" class="btn-icon" title="Editează"><i class="fas fa-edit"></i></a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
