@model UploadProjectViewModel
@{ ViewData["Title"] = "Încarcă Proiect"; }

<div class="card card-medium">
    <div class="card-header">
        <h2><i class="fas fa-upload"></i> Proiect Nou</h2>
    </div>
    <div class="card-body">
        <form asp-action="Upload" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="form-group">
                <label asp-for="Title"><i class="fas fa-heading"></i> Titlu proiect *</label>
                <input asp-for="Title" class="form-control" placeholder="ex: Aplicație Web pentru Gestionarea Bibliotecii" />
                <span asp-validation-for="Title" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Description"><i class="fas fa-align-left"></i> Descriere *</label>
                <textarea asp-for="Description" class="form-control" rows="5" placeholder="Descrie proiectul, tehnologiile utilizate, funcționalitățile principale..."></textarea>
                <span asp-validation-for="Description" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Deadline"><i class="fas fa-calendar-alt"></i> Termen limită</label>
                <input asp-for="Deadline" type="datetime-local" class="form-control" />
                <span asp-validation-for="Deadline" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="File"><i class="fas fa-paperclip"></i> Fișier proiect</label>
                <div class="file-upload-zone" id="dropZone">
                    <input asp-for="File" type="file" id="fileInput" class="file-input"
                           accept=".pdf,.zip,.rar,.docx,.doc,.pptx,.txt,.cs,.py,.js,.html"
                           onchange="updateFileName(this)" />
                    <div class="file-upload-label">
                        <i class="fas fa-cloud-upload-alt"></i>
                        <span id="fileLabel">Trageți fișierul aici sau <strong>click pentru a selecta</strong></span>
                        <small>PDF, ZIP, DOCX, PPTX – max 50 MB</small>
                    </div>
                </div>
                <span asp-validation-for="File" class="field-error"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-upload"></i> Încarcă proiect
                </button>
                <a asp-action="Projects" class="btn btn-secondary">Anulează</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
function updateFileName(input) {
    const label = document.getElementById('fileLabel');
    if (input.files && input.files[0]) {
        const size = (input.files[0].size / (1024*1024)).toFixed(2);
        label.innerHTML = `<strong>${input.files[0].name}</strong> (${size} MB)`;
        document.getElementById('dropZone').classList.add('has-file');
    }
}
</script>
}
