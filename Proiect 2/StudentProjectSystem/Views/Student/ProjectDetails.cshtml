@model Project
@{ ViewData["Title"] = "Detalii Proiect"; }

<div class="back-nav">
    <a asp-action="Projects"><i class="fas fa-arrow-left"></i> Înapoi la proiecte</a>
</div>

<div class="detail-layout">
    <div class="detail-main">
        <div class="card">
            <div class="card-header detail-header">
                <div>
                    <h2>@Model.Title</h2>
                    <div class="detail-meta">
                        <span><i class="fas fa-calendar"></i> @Model.UploadDate.ToString("dd MMMM yyyy, HH:mm")</span>
                        @if (Model.Deadline.HasValue)
                        { <span><i class="fas fa-hourglass-end"></i> Termen: @Model.Deadline.Value.ToString("dd.MM.yyyy")</span> }
                    </div>
                </div>
                <span class="status-badge status-@Model.Status.ToLower() status-lg">@Model.Status</span>
            </div>
            <div class="card-body">
                <h4>Descriere</h4>
                <p class="description-text">@Model.Description</p>

                @if (Model.FileName != null)
                {
                    <div class="file-attached">
                        <i class="fas fa-paperclip"></i>
                        <span>@Model.FileName</span>
                        @if (Model.FileSize.HasValue)
                        { <small>(@((Model.FileSize.Value / 1024.0 / 1024.0).ToString("F2")) MB)</small> }
                    </div>
                }
            </div>
        </div>

        <!-- Grade section -->
        @if (Model.Grade != null)
        {
            <div class="card grade-card">
                <div class="card-header">
                    <h3><i class="fas fa-star"></i> Evaluare</h3>
                </div>
                <div class="card-body">
                    <div class="grade-display">
                        <div class="grade-circle">@Model.Grade.Score</div>
                        <div class="grade-info">
                            <div class="grade-label">din 10</div>
                            <div class="grade-by">Prof. @Model.Grade.Professor?.FullName</div>
                            <div class="grade-date">@Model.Grade.GradedAt.ToString("dd.MM.yyyy")</div>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Grade.Feedback))
                    {
                        <div class="feedback-box">
                            <h4><i class="fas fa-comment-alt"></i> Feedback profesor</h4>
                            <p>@Model.Grade.Feedback</p>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Comments -->
        <div class="card">
            <div class="card-header">
                <h3><i class="fas fa-comments"></i> Comentarii (@Model.Comments.Count)</h3>
            </div>
            <div class="card-body">
                @foreach (var c in Model.Comments.OrderBy(x => x.CreatedAt))
                {
                    <div class="comment-item">
                        <div class="comment-avatar">@c.Author?.FullName?.FirstOrDefault()</div>
                        <div class="comment-body">
                            <div class="comment-header">
                                <strong>@c.Author?.FullName</strong>
                                <span class="comment-role role-@c.Author?.Role?.ToLower()">@c.Author?.Role</span>
                                <time>@c.CreatedAt.ToString("dd.MM.yyyy HH:mm")</time>
                            </div>
                            <p>@c.Content</p>
                        </div>
                    </div>
                }

                <form asp-action="AddComment" method="post" class="comment-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ProjectId" value="@Model.ProjectId" />
                    <div class="form-group">
                        <textarea name="Content" class="form-control" rows="3" placeholder="Adaugă un comentariu..." required></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary btn-sm">
                        <i class="fas fa-paper-plane"></i> Trimite
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="detail-sidebar">
        <div class="card">
            <div class="card-body">
                <h4>Acțiuni</h4>
                @if (Model.Status != "Graded" && !(Model.Deadline.HasValue && Model.Deadline < DateTime.UtcNow))
                {
                    <a asp-action="EditProject" asp-route-id="@Model.ProjectId" class="btn btn-outline btn-full mb-2">
                        <i class="fas fa-edit"></i> Editează proiect
                    </a>
                }
                @if (Model.FilePath != null)
                {
                    <a href="@Model.FilePath" download class="btn btn-secondary btn-full">
                        <i class="fas fa-download"></i> Descarcă fișier
                    </a>
                }
            </div>
        </div>
    </div>
</div>
