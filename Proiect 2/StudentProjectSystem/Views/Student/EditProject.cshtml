@model EditProjectViewModel
@{ ViewData["Title"] = "Editează Proiect"; }

<div class="card card-medium">
    <div class="card-header">
        <h2><i class="fas fa-edit"></i> Editează Proiect</h2>
    </div>
    <div class="card-body">
        <form asp-action="EditProject" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="ProjectId" />
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="form-group">
                <label asp-for="Title"></label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="field-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="Description"></label>
                <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                <span asp-validation-for="Description" class="field-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="Deadline"></label>
                <input asp-for="Deadline" type="datetime-local" class="form-control" />
            </div>
            <div class="form-group">
                <label asp-for="File">Fișier nou (opțional)</label>
                <input asp-for="File" type="file" class="form-control"
                       accept=".pdf,.zip,.rar,.docx,.doc,.pptx,.txt,.cs,.py,.js,.html" />
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Salvează</button>
                <a asp-action="Projects" class="btn btn-secondary">Anulează</a>
            </div>
        </form>
    </div>
</div>
