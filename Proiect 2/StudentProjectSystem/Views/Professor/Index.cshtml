@model ProfessorDashboardViewModel
@{ ViewData["Title"] = "Dashboard Profesor"; }

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon blue"><i class="fas fa-folder-open"></i></div>
        <div class="stat-info">
            <div class="stat-value">@Model.TotalProjects</div>
            <div class="stat-label">Total Proiecte</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon orange"><i class="fas fa-clock"></i></div>
        <div class="stat-info">
            <div class="stat-value">@Model.PendingProjects</div>
            <div class="stat-label">De evaluat</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon green"><i class="fas fa-check-double"></i></div>
        <div class="stat-info">
            <div class="stat-value">@Model.GradedProjects</div>
            <div class="stat-label">Evaluate</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon gray"><i class="fas fa-archive"></i></div>
        <div class="stat-info">
            <div class="stat-value">@Model.ArchivedProjects</div>
            <div class="stat-label">Arhivate</div>
        </div>
    </div>
</div>

@if (Model.UnreadNotifications > 0)
{
    <div class="alert alert-info">
        <i class="fas fa-bell"></i>
        Ai <strong>@Model.UnreadNotifications</strong> notificări noi.
        <a asp-action="Notifications">Vizualizează</a>
    </div>
}

<div class="section-header">
    <h3><i class="fas fa-inbox"></i> Proiecte recente</h3>
    <a asp-action="Projects" class="btn btn-outline btn-sm"><i class="fas fa-list"></i> Toate</a>
</div>

@if (!Model.RecentProjects.Any())
{
    <div class="empty-state">
        <i class="fas fa-inbox"></i>
        <h3>Niciun proiect</h3>
        <p>Nu există proiecte trimise momentan.</p>
    </div>
}
else
{
    <div class="projects-grid">
        @foreach (var p in Model.RecentProjects)
        {
            <div class="project-card">
                <div class="project-card-header">
                    <span class="status-badge status-@p.Status.ToLower()">@p.Status</span>
                    @if (p.Grade != null)
                    { <span class="grade-badge">@p.Grade.Score<small>/10</small></span> }
                </div>
                <h4 class="project-title">@p.Title</h4>
                <div class="project-student">
                    <i class="fas fa-user-graduate"></i> @p.Student?.FullName
                </div>
                <div class="project-meta">
                    <span><i class="fas fa-calendar"></i> @p.UploadDate.ToString("dd.MM.yyyy")</span>
                </div>
                <a asp-action="ProjectDetails" asp-route-id="@p.ProjectId" class="btn btn-outline btn-sm">
                    <i class="fas fa-eye"></i> @(p.Grade == null ? "Evaluează" : "Detalii")
                </a>
            </div>
        }
    </div>
}
